{
  "name": "tesla-grid-studio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c cyan,white \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx watch server/dev.ts",
    "dev:web": "vite",
    "build": "tsc -b && vite build",
    "bootstrap": "cdk bootstrap",
    "deploy": "npm run build && cdk bootstrap && cdk deploy --require-approval never",
    "destroy": "cdk destroy --force",
    "lint": "eslint .",
    "preview": "vite preview",
    "synth": "npm run build && cdk synth",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1023.0",
    "@aws-sdk/lib-dynamodb": "^3.1023.0",
    "@fontsource/manrope": "^5.2.8",
    "@fontsource/sora": "^5.2.8",
    "@hono/node-server": "^1.19.12",
    "framer-motion": "^12.38.0",
    "hono": "^4.12.10",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "aws-cdk": "^2.1116.0",
    "aws-cdk-lib": "^2.247.0",
    "concurrently": "^9.2.1",
    "constructs": "^10.6.0",
    "esbuild": "^0.27.7",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.2"
  }
}
